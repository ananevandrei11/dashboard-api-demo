{
  "name": "dashboard-api-demo",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "frontendlabtest",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "tsx watch --inspect=localhost:9229 src/main.ts",
    "dev:inspect": "nodemon -e ts,json --exec node --inspect=localhost:9229 --import tsx/esm src/main.ts",
    "build": "tsc --noEmit false --rootDir src --outDir dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "express": "5.2.1",
    "inversify": "8.1.0",
    "reflect-metadata": "0.2.2",
    "tslog": "4.10.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "24.13.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  }
}
